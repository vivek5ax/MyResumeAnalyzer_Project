# Groq AI enrichment controls
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: chatbot-specific override and fallback model for 429 handling
CHATBOT_GROQ_MODEL=llama-3.1-8b-instant
CHATBOT_GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=18
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MAX_RETRIES=2

# true/false - master switch
AI_ENRICHMENT_ENABLED=true

# shadow: generate AI insights without changing deterministic scoring
# active: reserved for future bounded score impact
AI_ENRICHMENT_MODE=shadow

# Database and auth
MONGODB_URI=your_mongodb_connection_string
DATABASE_NAME=resume_analyzer
JWT_SECRET_KEY=replace_with_a_secure_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
BCRYPT_ROUNDS=12

# App behavior
CHATBOT_ENABLED=true

# Frontend URL(s) allowed by CORS. Use comma-separated values in production if needed.
FRONTEND_ORIGIN=http://localhost:5173
